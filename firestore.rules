rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rogerjade82@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.keys().hasAll(['uid', 'displayName', 'email']) &&
             (!('isAdmin' in data) || data.isAdmin == false); // Users can't make themselves admin
    }

    function isValidAuction(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.startingPrice is number && data.startingPrice >= 0 &&
             data.endTime is timestamp && data.endTime > request.time &&
             data.status in ['active', 'ended'] &&
             data.createdBy == request.auth.uid;
    }

    function isValidBid(data, auctionData) {
      return data.auctionId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.amount is number &&
             data.amount > (auctionData.currentBid > 0 ? auctionData.currentBid : auctionData.startingPrice) &&
             data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /auctions/{auctionId} {
      allow read: if true; // Public listings
      allow create: if isAdmin() && isValidId(auctionId) && isValidAuction(incoming());
      allow update: if isSignedIn() && (
        // Admin full update
        (isAdmin() && isValidAuction(incoming())) ||
        // User bidding (updates currentBid and highestBidderId only)
        (
          existing().status == 'active' &&
          existing().endTime > request.time &&
          incoming().diff(existing()).affectedKeys().hasOnly(['currentBid', 'highestBidderId', 'highestBidderName']) &&
          incoming().currentBid > existing().currentBid &&
          incoming().currentBid > existing().startingPrice &&
          incoming().highestBidderId == request.auth.uid
        )
      );
      allow delete: if isAdmin();

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isSignedIn() &&
                         isValidId(bidId) &&
                         get(/databases/$(database)/documents/auctions/$(auctionId)).data.status == 'active' &&
                         get(/databases/$(database)/documents/auctions/$(auctionId)).data.endTime > request.time &&
                         isValidBid(incoming(), get(/databases/$(database)/documents/auctions/$(auctionId)).data);
        allow update, delete: if false; // Bids are immutable
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or system
    }
  }
}
